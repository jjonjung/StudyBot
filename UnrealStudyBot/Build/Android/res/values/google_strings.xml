<?xml version="1.0" encoding="utf-8"?>
<!--
    Google Sign-In Web Client ID 리소스

    Google Cloud Console > OAuth 2.0 클라이언트 ID 에서 발급받은
    "웹 애플리케이션" 유형의 클라이언트 ID를 입력하세요.

    주의:
      - "Android" 유형 ID가 아닌 "웹 애플리케이션" 유형 ID여야 합니다.
      - 이 값은 서버의 config.json google.clientId 와 동일해야 합니다.
      - 실제 값은 .gitignore 처리를 권장합니다 (google-services.json 사용 권장).
-->
<resources>
    <string name="google_web_client_id">YOUR_WEB_CLIENT_ID.apps.googleusercontent.com</string>
</resources>
